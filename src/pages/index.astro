---
// Bespoke MUSE landing page.
// Docs/manual routes remain on Starlight; only the homepage is custom.
import logo from '../assets/muse-logo.svg';

const base = import.meta.env.BASE_URL; // "/muse-site/"
const GITHUB = 'https://github.com/atomic-rose/muse-site';
const RELEASE = 'https://github.com/Atomic-Rose/muse-site/releases/tag/v0.1.0-alpha.1';

const href = {
  download: RELEASE,
  manual: `${base}manual/getting-started/`,
  whatIsMuse: `${base}manual/what-is-muse/`,
  install: `${base}alpha/install/`,
  privacy: `${base}privacy/`,
  github: GITHUB,
};

const nav = [
  { label: 'Features', href: '#features' },
  { label: 'Safety', href: '#safety' },
  { label: 'Download', href: href.download, external: true },
  { label: 'Manual', href: href.manual },
  { label: 'GitHub', href: href.github, external: true },
];

const trust = [
  { label: 'Offline by default', note: 'Works with no internet connection.' },
  { label: 'One .muse file', note: 'Your whole book in a single document.' },
  { label: 'Automatic backups', note: 'Quiet, continuous protection.' },
  { label: 'No account or telemetry', note: 'Nothing is uploaded, ever.' },
];

// Consistent stroke line-icons used across feature/safety sections.
const sw = 'stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"';
const icons = {
  organize: `<svg viewBox="0 0 24 24" fill="none" ${sw} aria-hidden="true"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M9 4v16"/><path d="M5.4 8h1.6M5.4 11.5h1.6M12.5 8.5h5M12.5 12h5M12.5 15.5h3"/></svg>`,
  plan: `<svg viewBox="0 0 24 24" fill="none" ${sw} aria-hidden="true"><rect x="3" y="3" width="7.5" height="7.5" rx="1.4"/><rect x="13.5" y="3" width="7.5" height="7.5" rx="1.4"/><rect x="3" y="13.5" width="7.5" height="7.5" rx="1.4"/><rect x="13.5" y="13.5" width="7.5" height="7.5" rx="1.4"/></svg>`,
  revise: `<svg viewBox="0 0 24 24" fill="none" ${sw} aria-hidden="true"><path d="M12 20h9"/><path d="M16.4 3.6a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>`,
  exportFmt: `<svg viewBox="0 0 24 24" fill="none" ${sw} aria-hidden="true"><path d="M12 15V3"/><path d="m8 7 4-4 4 4"/><path d="M4 14v5a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-5"/></svg>`,
  safety: `<svg viewBox="0 0 24 24" fill="none" ${sw} aria-hidden="true"><path d="M12 3 5 6v5c0 4.5 3 7.6 7 9 4-1.4 7-4.5 7-9V6Z"/><path d="m9.4 12 1.9 1.9L15 10"/></svg>`,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>MUSE — One calm studio for the whole book</title>
    <meta
      name="description"
      content="MUSE is an offline desktop writing app for people who write long things plan, draft, revise, and export a manuscript without giving your work to the cloud."
    />
    <meta property="og:title" content="MUSE — One calm studio for the whole book" />
    <meta
      property="og:description"
      content="An offline desktop writing app for novelists and long-form writers. Plan, draft, revise, and export a whole book — your work stays on your computer."
    />
    <meta property="og:type" content="website" />
    <script is:inline>
      // Set the theme before paint to avoid a flash of the wrong theme.
      (function () {
        try {
          var starlightStored = localStorage.getItem('starlight-theme');
          var museStored = localStorage.getItem('muse-theme');
          var stored =
            starlightStored === 'dark' || starlightStored === 'light'
              ? starlightStored
              : starlightStored === ''
                ? null
                : museStored;
          var theme =
            stored ||
            (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.dataset.theme = theme;
          if (
            starlightStored === null &&
            (museStored === 'dark' || museStored === 'light')
          ) {
            localStorage.setItem('starlight-theme', museStored);
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header">
      <div class="wrap header-inner">
        <a class="brand" href={base} aria-label="MUSE home">
          <img src={logo.src} alt="" width="32" height="32" />
          <span class="wordmark">MUSE</span>
        </a>
        <nav class="primary-nav" aria-label="Primary">
          <ul>
            {
              nav.map((item) => (
                <li>
                  <a
                    href={item.href}
                    {...(item.external
                      ? { rel: 'noopener', target: '_blank' }
                      : {})}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
          <button
            type="button"
            class="theme-toggle"
            id="theme-toggle"
            aria-label="Switch to dark theme"
            aria-pressed="false"
          >
            <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.8A8.5 8.5 0 1 1 11.2 3a6.6 6.6 0 0 0 9.8 9.8Z"/></svg>
            <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
          </button>
          <a class="btn btn-primary btn-sm nav-cta" href={href.download} rel="noopener" target="_blank">Download</a>
        </nav>
      </div>
    </header>

    <main id="main">
      <!-- HERO -->
      <section class="hero" aria-labelledby="hero-heading">
        <div class="wrap hero-grid">
          <div class="hero-copy">
            <p class="eyebrow">
              <img src={logo.src} alt="" width="20" height="20" aria-hidden="true" />
              Manuscript Unified Studio Environment
            </p>
            <h1 id="hero-heading">One calm studio for the whole book.</h1>
            <p class="lede">
              MUSE is an offline desktop writing app for people who write long things,
              built to help you plan, draft, revise, and export a manuscript.
            </p>
            <div class="cta-row">
              <a class="btn btn-primary" href={href.download} rel="noopener" target="_blank">Download the alpha</a>
              <a class="btn btn-ghost" href={href.manual}>Read the manual</a>
            </div>
            <p class="platforms">Windows 11 · macOS · Linux · Private alpha</p>
          </div>

          <div class="hero-visual" aria-hidden="true">
            <div class="mock mock-editor">
              <div class="m-bar">
                <span class="m-doc-title">The Glass Observatory</span>
                <span class="m-tabs"><b>Editor</b><span>Home</span><span>Insert</span><span>Review</span></span>
              </div>
              <div class="m-toolbar">
                <span class="m-field">Normal</span>
                <span class="m-field">Georgia</span>
                <span class="m-field sm">16</span>
                <span class="m-sep"></span>
                <span class="m-btn">B</span><span class="m-btn i">I</span><span class="m-btn u">U</span>
                <span class="m-sep"></span>
                <span class="m-dots"><i></i><i></i><i></i></span>
              </div>
              <div class="m-pagewrap">
                <div class="m-page">
                  <p>
                    Nora Quill had spent twenty years making public meetings feel
                    inevitable. She knew where to place the water glasses, when to clear
                    her throat, and which silence would force a councilor to reveal fear.
                  </p>
                  <p>
                    The demonstration should have been harmless. Mara would show the
                    <span class="sp">rainlight</span>, Cassian would mutter about
                    interference, and Nora would file a careful report with careful blanks.
                  </p>
                </div>
              </div>
              <div class="m-status">
                <span>94 words</span>
                <span class="m-spacer"></span>
                <span>Saved</span>
                <span class="m-pill">In Export</span>
                <span>100%</span>
              </div>
            </div>
            <div class="hero-glow"></div>
          </div>
        </div>

        <!-- TRUST STRIP -->
        <div class="wrap">
          <ul class="trust-strip">
            {
              trust.map((t) => (
                <li>
                  <span class="trust-tick" aria-hidden="true" />
                  <span class="trust-text">
                    <span class="trust-label">{t.label}</span>
                    <span class="trust-note">{t.note}</span>
                  </span>
                </li>
              ))
            }
          </ul>
        </div>
      </section>

      <!-- FEATURES -->
      <div id="features"></div>

      <section class="band" aria-labelledby="f1">
        <div class="wrap band-grid">
          <div class="band-copy">
            <span class="sec-icon" set:html={icons.organize} />
            <p class="kicker">Organize</p>
            <h2 id="f1">Organize a whole manuscript.</h2>
            <p>
              Keep chapters, scenes, characters, places, and research in one
              drag-and-drop binder — your entire book in a single window.
            </p>
            <ul class="pills">
              <li>Drag-and-drop binder</li>
              <li>Labels, status &amp; metadata</li>
              <li>Smart collections</li>
            </ul>
          </div>
          <div class="band-visual" aria-hidden="true">
            <div class="mock mock-binder">
              <div class="m-binder-top"><span>BINDER</span><span class="m-template">Template</span></div>
              <div class="m-binder-label">COLLECTIONS</div>
              <ul class="m-tree">
                <li class="t-folder">Manuscript</li>
                <li class="t-folder d1">Act I — The Signal</li>
                <li class="t-doc d2 active"><i class="lab blue"></i>1. The Rain Inside the Lens</li>
                <li class="t-doc d2">2. Mara Finds the Map</li>
                <li class="t-doc d2"><i class="lab purple"></i>3. The Observatory Wakes</li>
                <li class="t-doc d2"><i class="lab green"></i>4. A Public Demonstration</li>
                <li class="t-folder d1 closed">Act II — The Mirror City</li>
                <li class="t-folder closed">Characters</li>
                <li class="t-folder closed">Research</li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <section class="band band-alt band-plan" aria-labelledby="f2">
        <div class="wrap band-grid">
          <div class="band-copy">
            <span class="sec-icon" set:html={icons.plan} />
            <p class="kicker">Plan</p>
            <h2 id="f2">See the story before you rewrite it.</h2>
            <p>
              Step back from the page and see your manuscript as a whole. Rearrange
              scenes on a spatial canvas, and follow the characters that
              run through your story.
            </p>
            <ul class="pills">
              <li>Corkboard &amp; canvas</li>
              <li>Outliner</li>
            </ul>
          </div>
          <div class="band-visual" aria-hidden="true">
            <div class="mock mock-canvas">
              <svg class="m-connect" viewBox="0 0 100 100" preserveAspectRatio="none">
                <path d="M26 34 C 48 46, 50 54, 72 66" fill="none" stroke="currentColor" stroke-width="0.7" />
              </svg>
              <div class="m-group">
                <span class="m-group-tag">Act I: Signal</span>
                <div class="m-sgrid">
                  <div class="m-scard">
                    <b>1. The Rain Inside…</b>
                    <span>Mara discovers impossible weather falling inside a sealed lens.</span>
                    <em>To Do · 103</em>
                  </div>
                  <div class="m-scard">
                    <b>2. Mara Finds the Map</b>
                    <span>A hidden calibration room reveals weather that hasn't happened yet.</span>
                    <em>In Progress · 104</em>
                  </div>
                </div>
              </div>
              <div class="m-group alt">
                <span class="m-group-tag">Act II: Mirror City</span>
                <div class="m-sgrid">
                  <div class="m-scard"><i class="lab green"></i><b>5. Beneath Meridian</b><span>Cassian leads Mara under the old rail terminal.</span><em>In Progress · 105</em></div>
                  <div class="m-scard"><i class="lab gold"></i><b>6. The Orchard</b><span>An archive where storms grow on trees.</span><em>First Draft · 89</em></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="band" aria-labelledby="f3">
        <div class="wrap band-grid">
          <div class="band-copy">
            <span class="sec-icon" set:html={icons.revise} />
            <p class="kicker">Write &amp; revise</p>
            <h2 id="f3">Write and revise without friction.</h2>
            <p>
              A fast editor that stays smooth at 120,000 words, with the revision tools a
              serious draft needs tracked changes, comments, and snapshots you can roll
              back to.
            </p>
            <ul class="pills">
              <li>Focus mode &amp; typewriter</li>
              <li>Wikilinks &amp; backlinks</li>
              <li>Tracked changes &amp; snapshots</li>
            </ul>
          </div>
          <div class="band-visual" aria-hidden="true">
            <div class="mock mock-revise">
              <div class="m-rev-main">
                <p>
                  Cassian Roe entered the tunnels with
                  <span class="m-del">three lies prepared</span> and used all of them
                  before the first locked gate.
                </p>
                <div class="m-pop">
                  <div class="m-pop-h">DELETION<span>Line Edit</span></div>
                  <div class="m-pop-d">three lies prepared</div>
                  <div class="m-pop-a"><span class="ok">✓ Accept</span><span class="no">✕ Reject</span></div>
                </div>
                <p>
                  The prism key waited inside a ticket booth wrapped in salt cloth, smaller
                  than Mara had expected.
                </p>
              </div>
              <aside class="m-rev-side">
                <div class="m-side-h">REVISION PASSES</div>
                <div class="m-pass green"><i class="lab green"></i><b>Final Polish</b><small>1 pending</small></div>
                <div class="m-pass orange"><i class="lab orange"></i><b>Line Edit</b><small>2 pending</small></div>
                <div class="m-side-sub">VISIBILITY</div>
                <div class="m-vchips"><span class="vchip green">Final Polish</span><span class="vchip orange">Line Edit</span></div>
              </aside>
            </div>
          </div>
        </div>
      </section>

      <section class="band band-alt" aria-labelledby="f4">
        <div class="wrap band-grid">
          <div class="band-copy">
            <span class="sec-icon" set:html={icons.exportFmt} />
            <p class="kicker">Export</p>
            <h2 id="f4">Export to real manuscript formats.</h2>
            <p>
              Compile the documents you choose into a finished manuscript and export to
              the formats editors and agents actually use.
            </p>
            <ul class="pills">
              <li>DOCX with tracked changes</li>
              <li>PDF</li>
              <li>Markdown</li>
            </ul>
          </div>
          <div class="band-visual" aria-hidden="true">
            <div class="mock mock-compile">
              <div class="m-comp-h">Compile Manuscript</div>
              <div class="m-comp-body">
                <div class="m-comp-tree">
                  <div class="m-comp-sub">INCLUDE · 12 docs</div>
                  <p>☑ Manuscript</p>
                  <p class="i1">☑ Act I — The Signal</p>
                  <p class="i2">☑ 1. The Rain Inside…</p>
                  <p class="i2">☑ 2. Mara Finds the Map</p>
                  <p class="i1">☑ Act II — Mirror City</p>
                </div>
                <div class="m-comp-mid">
                  <label>Preset<span>Novel Manuscript</span></label>
                  <label>Output format<span>Word Document (.docx)</span></label>
                  <label>Track changes<span>Keep as-is</span></label>
                  <div class="m-seg"><span class="on">Page</span><span>Scene</span><span>None</span></div>
                </div>
                <div class="m-comp-prev">
                  <div class="m-prev-page">
                    <span class="t">THE GLASS<br />OBSERVATORY</span>
                    <span class="by">by Muse Demo Team</span>
                  </div>
                </div>
              </div>
              <div class="m-comp-foot"><span>Cancel</span><span class="m-comp-go">Compile</span></div>
            </div>
          </div>
        </div>
      </section>

      <!-- SAFETY -->
      <section id="safety" class="safety" aria-labelledby="safety-heading">
        <div class="wrap safety-inner">
          <span class="sec-icon center" set:html={icons.safety} />
          <p class="kicker center">Ownership</p>
          <h2 id="safety-heading">Your manuscript stays yours.</h2>
          <p class="safety-lede">
            MUSE stores your project locally in a single <code>.muse</code> file on your
            own disk. No cloud account, no sync service, no telemetry.
          </p>
          <ul class="safety-points">
            <li><strong>Automatic backups</strong><span>Quiet, continuous copies as you work.</span></li>
            <li><strong>Version snapshots</strong><span>Roll a document back to an earlier draft.</span></li>
            <li><strong>Crash-recovery drafts</strong><span>Unsaved work is restored on reopen.</span></li>
            <li><strong>Yours to move</strong><span>Copy the file to a USB stick or any folder.</span></li>
          </ul>
        </div>
      </section>

      <!-- ALPHA -->
      <section class="alpha" aria-labelledby="alpha-heading">
        <div class="wrap">
          <div class="alpha-inner">
            <p class="kicker center">Early access</p>
            <h2 id="alpha-heading">Now in private alpha.</h2>
            <p>
              MUSE is in early testing. Expect rough edges, keep backups of work you cannot
              afford to lose, and help shape the 1.0 release. Alpha and beta testers receive
              a <strong>generous one-time discount</strong> at launch.
            </p>
            <div class="cta-row center">
              <a class="btn btn-primary" href={href.download} rel="noopener" target="_blank">Download the alpha</a>
              <a class="btn btn-ghost" href={href.install}>Read install instructions</a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="wrap footer-inner">
        <div class="footer-brand">
          <img src={logo.src} alt="" width="28" height="28" />
          <span class="wordmark">MUSE</span>
        </div>
        <nav class="footer-nav" aria-label="Footer">
          <a href={href.whatIsMuse}>What is MUSE?</a>
          <a href={href.manual}>Manual</a>
          <a href={href.privacy}>Privacy</a>
          <a href={href.github} rel="noopener" target="_blank">GitHub</a>
        </nav>
        <p class="footer-note">
          Private alpha · keep backups of anything you can’t afford to lose.
        </p>
      </div>
    </footer>

    <style is:global>
      :root {
        /* Clean, elegant light theme — warm paper, deep-blue ink accent. */
        --bg: #fbfaf7;
        --bg-soft: #f3f1ea;
        --surface: #ffffff;
        --text: #1c2a33;
        --muted: #586771;
        --muted-2: #8b949b;
        --border: #e7e2d7;
        --border-soft: #eee9df;

        --accent: #2e4d66; /* logo deep blue */
        --accent-hover: #243f56;
        --accent-soft: #e9eff4; /* light blue highlight */
        --accent-ink: #20384b;
        --gold: #b08a36; /* used sparingly */
        --blue: #6a9dbe;

        /* Component tokens that the dark theme remaps. */
        --btn-bg: #284763;
        --btn-bg-hover: #1f3a52;
        --btn-text: #ffffff;
        --skeleton: rgba(28, 42, 51, 0.09);
        --window-dot: #cfc9bb;

        --shadow-sm: 0 1px 2px rgba(28, 42, 51, 0.06);
        --shadow-md: 0 10px 30px -14px rgba(28, 42, 51, 0.22);
        --shadow-lg: 0 30px 60px -28px rgba(28, 42, 51, 0.28);

        --maxw: 74rem;
        --radius: 14px;
        --font-sans: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto,
          'Helvetica Neue', Arial, sans-serif;
        --font-serif: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia,
          'Times New Roman', serif;
      }

      /* Clean, elegant dark theme — deep slate, soft light ink, brighter blue. */
      :root[data-theme='dark'] {
        --bg: #0f161b;
        --bg-soft: #141d24;
        --surface: #18222a;
        --text: #eef2f4;
        --muted: #a6b2ba;
        --muted-2: #74828b;
        --border: #2a3640;
        --border-soft: #232e37;

        --accent: #84b3da;
        --accent-hover: #9cc4e6;
        --accent-soft: rgba(132, 179, 218, 0.16);
        --accent-ink: #d3e4f1;
        --gold: #cda85a;
        --blue: #8fb7d9;

        --btn-bg: #84b3da;
        --btn-bg-hover: #9cc4e6;
        --btn-text: #0e151a;
        --skeleton: rgba(245, 248, 250, 0.11);
        --window-dot: #3a4750;

        --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.4);
        --shadow-md: 0 12px 30px -14px rgba(0, 0, 0, 0.6);
        --shadow-lg: 0 34px 64px -30px rgba(0, 0, 0, 0.7);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      html,
      body {
        margin: 0;
        max-width: 100%;
        overflow-x: hidden;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--font-sans);
        font-size: 1.06rem;
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      img {
        max-width: 100%;
        height: auto;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      :focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
        border-radius: 4px;
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
        * {
          transition-duration: 0.01ms !important;
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
        }
      }
    </style>

    <style>
      .wrap {
        width: 100%;
        max-width: var(--maxw);
        margin-inline: auto;
        padding-inline: clamp(1.1rem, 4vw, 2.5rem);
      }

      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--btn-bg);
        color: var(--btn-text);
        padding: 0.6rem 1rem;
        font-weight: 600;
        z-index: 100;
      }
      .skip-link:focus {
        left: 1rem;
        top: 1rem;
      }

      /* ---------- buttons ---------- */
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        font-family: var(--font-sans);
        font-weight: 600;
        font-size: 1rem;
        line-height: 1;
        padding: 0.88rem 1.55rem;
        border-radius: 10px;
        border: 1px solid transparent;
        cursor: pointer;
        transition:
          transform 0.16s ease,
          background-color 0.16s ease,
          border-color 0.16s ease,
          box-shadow 0.16s ease;
      }
      .btn-sm {
        padding: 0.5rem 1.05rem;
        font-size: 0.92rem;
        border-radius: 8px;
      }
      .btn-primary {
        background: var(--btn-bg);
        color: var(--btn-text);
        box-shadow: var(--shadow-sm);
      }
      .btn-primary:hover {
        background: var(--btn-bg-hover);
        transform: translateY(-1px);
        box-shadow: var(--shadow-md);
      }
      .btn-ghost {
        background: var(--surface);
        color: var(--text);
        border-color: var(--border);
        box-shadow: var(--shadow-sm);
      }
      .btn-ghost:hover {
        border-color: var(--muted-2);
        transform: translateY(-1px);
        box-shadow: var(--shadow-md);
      }

      /* ---------- header ---------- */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: color-mix(in srgb, var(--bg) 82%, transparent);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
      }
      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 64px;
      }
  
      .brand img {
        border-radius: 8px;
      }
      .wordmark {
        font-family: var(--font-sans);
        font-weight: 700;
        letter-spacing: 0.2em;
        font-size: 1rem;
        color: var(--text);
      }
      .primary-nav {
        display: flex;
        align-items: center;
        gap: 1.5rem;
      }
      .primary-nav ul {
        display: flex;
        align-items: center;
        gap: 1.7rem;
        margin: 0;
        padding: 0;
        list-style: none;
      }
      .primary-nav ul a {
        color: var(--muted);
        font-size: 0.95rem;
        font-weight: 500;
        transition: color 0.15s ease;
      }
      .primary-nav ul a:hover {
        color: var(--text);
      }
      .nav-cta {
        white-space: nowrap;
        font-weight: 700;
        letter-spacing: 0.01em;
      }

      /* ---------- theme toggle ---------- */
      .theme-toggle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 38px;
        height: 38px;
        padding: 0;
        border: 1px solid var(--border);
        border-radius: 9px;
        background: var(--surface);
        color: var(--muted);
        cursor: pointer;
        transition:
          color 0.15s ease,
          border-color 0.15s ease,
          background-color 0.15s ease;
      }
      .theme-toggle:hover {
        color: var(--text);
        border-color: var(--muted-2);
      }
      .theme-toggle svg {
        width: 18px;
        height: 18px;
      }
      .theme-toggle .icon-sun {
        display: none;
      }
      :root[data-theme='dark'] .theme-toggle .icon-sun {
        display: block;
      }
      :root[data-theme='dark'] .theme-toggle .icon-moon {
        display: none;
      }

      /* ---------- hero ---------- */
      .hero {
        position: relative;
        padding-top: clamp(3rem, 7vh, 5.5rem);
        padding-bottom: clamp(2.5rem, 6vh, 4.5rem);
        background:
          radial-gradient(46% 40% at 82% 6%, rgba(106, 157, 190, 0.12), transparent 70%);
      }
      .hero-grid {
        display: grid;
        grid-template-columns: 1fr 1.1fr;
        gap: clamp(2rem, 5vw, 4.5rem);
        align-items: center;
      }
      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        margin: 0 0 1.2rem;
        color: var(--accent);
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
      }
      .eyebrow img {
        border-radius: 6px;
      }
      h1 {
        font-family: var(--font-serif);
        font-weight: 600;
        font-size: clamp(2.3rem, 4.4vw, 3.5rem);
        line-height: 1.08;
        letter-spacing: -0.02em;
        margin: 0 0 1.3rem;
        text-wrap: balance;
      }
      .lede {
        color: var(--muted);
        font-size: clamp(1.08rem, 1.4vw, 1.22rem);
        line-height: 1.62;
        max-width: 42ch;
        margin: 0 0 2rem;
      }
      .cta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.9rem;
      }
      .cta-row.center {
        justify-content: center;
      }
      .platforms {
        margin: 1.6rem 0 0;
        color: var(--muted-2);
        font-size: 0.92rem;
        letter-spacing: 0.02em;
      }

      /* ---------- hero / section screenshots ---------- */
      .hero-visual {
        position: relative;
      }
      .hero-glow {
        position: absolute;
        inset: 10% 4% 4% 10%;
        z-index: -1;
        background: radial-gradient(closest-side, rgba(46, 77, 102, 0.16), transparent);
        filter: blur(50px);
      }
      /* ---------- vector UI mockups (theme-aware, crisp at any DPI) ---------- */
      .mock {
        width: 100%;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
        background: var(--surface);
        box-shadow: var(--shadow-lg);
        font-family: var(--font-sans);
        font-size: 0.74rem;
        line-height: 1.5;
        color: var(--text);
      }
      .mock .lab {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        flex: none;
      }
      .lab.blue { background: var(--blue); }
      .lab.gold { background: var(--gold); }
      .lab.purple { background: #9a7bd0; }
      .lab.green { background: #54a574; }
      .lab.orange { background: #d6924a; }

      /* Editor (hero) */
      .m-bar {
        display: flex;
        align-items: center;
        gap: 0.8rem;
        padding: 0.5rem 0.8rem;
        border-bottom: 1px solid var(--border);
        background: var(--bg-soft);
      }
      .m-doc-title { font-weight: 600; }
      .m-tabs { display: flex; gap: 0.7rem; color: var(--muted-2); font-size: 0.68rem; }
      .m-tabs b { color: var(--accent); font-weight: 600; }
      .m-toolbar {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.4rem 0.8rem;
        border-bottom: 1px solid var(--border);
        background: var(--surface);
      }
      .m-field {
        border: 1px solid var(--border);
        border-radius: 5px;
        padding: 0.12rem 0.45rem;
        color: var(--muted);
        font-size: 0.64rem;
      }
      .m-field.sm { padding-inline: 0.35rem; }
      .m-btn {
        width: 1.1rem;
        text-align: center;
        font-weight: 700;
        font-size: 0.66rem;
        color: var(--muted);
      }
      .m-btn.i { font-style: italic; font-weight: 600; }
      .m-btn.u { text-decoration: underline; }
      .m-sep { width: 1px; height: 13px; background: var(--border); }
      .m-dots { display: inline-flex; gap: 3px; }
      .m-dots i { width: 4px; height: 4px; border-radius: 50%; background: var(--muted-2); }
      .m-pagewrap { padding: 1.1rem 1.1rem 0; background: var(--bg-soft); }
      .m-page {
        background: var(--surface);
        border: 1px solid var(--border);
        border-bottom: none;
        border-radius: 6px 6px 0 0;
        box-shadow: var(--shadow-sm);
        padding: 1.1rem 1.3rem;
        font-family: var(--font-serif);
        font-size: 0.82rem;
        line-height: 1.65;
      }
      .m-page p { margin: 0 0 0.8rem; }
      .sp {
        text-decoration: underline wavy #d4534f;
        text-underline-offset: 2px;
      }
      .m-status {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        padding: 0.4rem 0.8rem;
        border-top: 1px solid var(--border);
        background: var(--bg-soft);
        color: var(--muted-2);
        font-size: 0.62rem;
      }
      .m-spacer { flex: 1; }
      .m-pill {
        border: 1px solid var(--border);
        border-radius: 999px;
        padding: 0.05rem 0.45rem;
        color: var(--accent);
      }

      /* Binder */
      .mock-binder { padding: 0.6rem 0.5rem; }
      .m-binder-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.1rem 0.4rem 0.4rem;
        font-weight: 700;
        letter-spacing: 0.04em;
        font-size: 0.68rem;
      }
      .m-template {
        font-weight: 500;
        color: var(--muted);
        border: 1px solid var(--border);
        border-radius: 5px;
        padding: 0.1rem 0.4rem;
        font-size: 0.6rem;
      }
      .m-binder-label {
        color: var(--muted-2);
        font-size: 0.58rem;
        letter-spacing: 0.1em;
        padding: 0.3rem 0.4rem;
      }
      .m-tree { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.12rem; }
      .m-tree li {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.3rem 0.45rem;
        border-radius: 6px;
        color: var(--muted);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .t-folder { color: var(--text); font-weight: 600; }
      .t-folder::before { content: '▾'; color: var(--muted-2); font-size: 0.7em; }
      .t-folder.closed::before { content: '▸'; }
      .t-folder.d1 { padding-left: 1.1rem; }
      .t-doc.d2 { padding-left: 1.9rem; }
      .t-doc.active {
        background: var(--accent-soft);
        color: var(--accent-ink);
        font-weight: 600;
      }

      /* Scene Board canvas */
      .mock-canvas {
        position: relative;
        display: flex;
        flex-direction: column;
        gap: 1.1rem;
        padding: 1.1rem;
        background-color: var(--bg-soft);
        background-image: radial-gradient(var(--border) 1px, transparent 1px);
        background-size: 13px 13px;
      }
      .m-connect {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        color: var(--accent);
        opacity: 0.5;
        pointer-events: none;
      }
      .m-group {
        position: relative;
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 0.7rem;
        background: color-mix(in srgb, var(--surface) 70%, transparent);
      }
      .m-group-tag {
        display: inline-block;
        margin-bottom: 0.55rem;
        padding: 0.1rem 0.45rem;
        border: 1px solid var(--border);
        border-radius: 5px;
        background: var(--surface);
        color: var(--muted);
        font-size: 0.62rem;
      }
      .m-sgrid { display: grid; grid-template-columns: 1fr 1fr; gap: 0.6rem; }
      .m-scard {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        padding: 0.55rem;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--surface);
        box-shadow: var(--shadow-sm);
      }
      .m-scard b { font-size: 0.7rem; }
      .m-scard span { color: var(--muted); font-size: 0.64rem; line-height: 1.4; }
      .m-scard em { margin-top: 0.1rem; color: var(--muted-2); font-size: 0.58rem; font-style: normal; }

      /* Revise */
      .mock-revise { display: grid; grid-template-columns: 1.55fr 1fr; }
      .m-rev-main {
        position: relative;
        padding: 1rem;
        border-right: 1px solid var(--border);
        font-family: var(--font-serif);
        font-size: 0.8rem;
        line-height: 1.7;
      }
      .m-rev-main p { margin: 0 0 0.7rem; }
      .m-del { color: #c0563f; text-decoration: line-through; }
      .m-pop {
        margin: 0.2rem 0 0.7rem auto;
        max-width: 72%;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--surface);
        box-shadow: var(--shadow-md);
        padding: 0.5rem 0.6rem;
        font-family: var(--font-sans);
      }
      .m-pop-h {
        display: flex;
        justify-content: space-between;
        color: var(--muted-2);
        font-size: 0.56rem;
        letter-spacing: 0.06em;
      }
      .m-pop-h span { color: #c08a45; }
      .m-pop-d {
        margin: 0.35rem 0;
        padding: 0.2rem 0.4rem;
        border-radius: 5px;
        background: rgba(192, 86, 63, 0.1);
        color: #c0563f;
        text-decoration: line-through;
        font-size: 0.66rem;
      }
      .m-pop-a { display: flex; gap: 0.4rem; font-size: 0.62rem; font-weight: 600; }
      .m-pop-a .ok { color: #3c9a63; }
      .m-pop-a .no { color: #c0563f; }
      .m-rev-side { padding: 0.7rem; background: var(--bg-soft); font-family: var(--font-sans); }
      .m-side-h { font-weight: 700; font-size: 0.6rem; letter-spacing: 0.06em; margin-bottom: 0.5rem; }
      .m-pass {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        margin-bottom: 0.4rem;
        padding: 0.4rem 0.5rem;
        border: 1px solid var(--border);
        border-left: 3px solid var(--muted-2);
        border-radius: 6px;
        background: var(--surface);
      }
      .m-pass.green { border-left-color: #54a574; }
      .m-pass.orange { border-left-color: #d6924a; }
      .m-pass b { flex: 1; font-size: 0.66rem; }
      .m-pass small { color: var(--muted-2); font-size: 0.56rem; }
      .m-side-sub { color: var(--muted-2); font-size: 0.56rem; letter-spacing: 0.06em; margin: 0.6rem 0 0.3rem; }
      .m-vchips { display: flex; flex-wrap: wrap; gap: 0.3rem; }
      .vchip { border: 1px solid var(--border); border-radius: 999px; padding: 0.1rem 0.5rem; font-size: 0.58rem; }
      .vchip.green { color: #3c9a63; }
      .vchip.orange { color: #c08a45; }

      /* Compile */
      .m-comp-h {
        padding: 0.55rem 0.8rem;
        border-bottom: 1px solid var(--border);
        font-weight: 600;
        font-size: 0.74rem;
      }
      .m-comp-body { display: grid; grid-template-columns: 0.9fr 1.1fr 0.85fr; }
      .m-comp-tree { padding: 0.6rem; border-right: 1px solid var(--border); color: var(--muted); }
      .m-comp-sub { color: var(--muted-2); font-size: 0.56rem; letter-spacing: 0.06em; margin-bottom: 0.4rem; }
      .m-comp-tree p { margin: 0.2rem 0; white-space: nowrap; font-size: 0.64rem; }
      .m-comp-tree .i1 { padding-left: 0.7rem; }
      .m-comp-tree .i2 { padding-left: 1.4rem; }
      .m-comp-mid { display: grid; gap: 0.45rem; align-content: start; padding: 0.6rem; border-right: 1px solid var(--border); }
      .m-comp-mid label { display: grid; gap: 0.15rem; color: var(--muted-2); font-size: 0.56rem; }
      .m-comp-mid label span {
        color: var(--text);
        font-size: 0.66rem;
        border: 1px solid var(--border);
        border-radius: 5px;
        padding: 0.25rem 0.4rem;
        background: var(--bg-soft);
      }
      .m-seg { display: flex; border: 1px solid var(--border); border-radius: 6px; overflow: hidden; }
      .m-seg span { flex: 1; text-align: center; padding: 0.25rem; color: var(--muted); font-size: 0.6rem; }
      .m-seg .on { background: var(--accent-soft); color: var(--accent-ink); font-weight: 600; }
      .m-comp-prev { display: grid; place-items: center; padding: 0.6rem; background: var(--bg-soft); }
      .m-prev-page {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        width: 100%;
        aspect-ratio: 3 / 4;
        border: 1px solid var(--border);
        background: var(--surface);
        box-shadow: var(--shadow-sm);
        text-align: center;
      }
      .m-prev-page .t { font-family: var(--font-serif); font-size: 0.6rem; letter-spacing: 0.08em; line-height: 1.4; }
      .m-prev-page .by { color: var(--muted); font-size: 0.52rem; }
      .m-comp-foot {
        display: flex;
        justify-content: flex-end;
        align-items: center;
        gap: 0.6rem;
        padding: 0.5rem 0.8rem;
        border-top: 1px solid var(--border);
      }
      .m-comp-foot span { color: var(--muted); font-size: 0.66rem; }
      .m-comp-go {
        background: var(--btn-bg);
        color: var(--btn-text) !important;
        border-radius: 6px;
        padding: 0.3rem 0.75rem;
        font-weight: 600;
      }

      /* ---------- trust strip ---------- */
      .trust-strip {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1px;
        margin: clamp(2.5rem, 6vh, 4rem) 0 0;
        padding: 0;
        list-style: none;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
        background: var(--border);
        box-shadow: var(--shadow-sm);
      }
      .trust-strip li {
        display: flex;
        align-items: flex-start;
        gap: 0.7rem;
        padding: 1.2rem 1.3rem;
        background: var(--surface);
      }
      .trust-tick {
        margin-top: 0.45rem;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex: none;
        background: var(--accent);
        box-shadow: 0 0 0 3px var(--accent-soft);
      }
      .trust-text {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
      }
      .trust-label {
        font-weight: 600;
        font-size: 0.98rem;
      }
      .trust-note {
        color: var(--muted);
        font-size: 0.84rem;
        line-height: 1.45;
      }

      /* ---------- section icon badge ---------- */
      .sec-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 42px;
        height: 42px;
        margin-bottom: 1.1rem;
        border: 1px solid var(--border);
        border-radius: 11px;
        background: var(--surface);
        color: var(--accent);
        box-shadow: var(--shadow-sm);
      }
      .sec-icon.center {
        margin-inline: auto;
      }
      .sec-icon svg {
        width: 21px;
        height: 21px;
      }

      /* ---------- feature bands ---------- */
      .band {
        padding: clamp(3.5rem, 8vh, 6rem) 0;
        border-top: 1px solid var(--border-soft);
      }
      .band-alt {
        background: var(--bg-soft);
      }
      .band-grid {
        display: grid;
        grid-template-columns: 1fr 1.05fr;
        gap: clamp(2rem, 5vw, 5rem);
        align-items: center;
      }
      .band-alt .band-copy {
        order: 2;
      }
      .band-plan .band-grid {
        grid-template-columns: 1fr 1.2fr;
      }
      .kicker {
        margin: 0 0 0.7rem;
        color: var(--accent);
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }
      .kicker.center {
        text-align: center;
      }
      h2 {
        font-family: var(--font-serif);
        font-weight: 600;
        font-size: clamp(1.8rem, 3vw, 2.5rem);
        line-height: 1.12;
        letter-spacing: -0.015em;
        margin: 0 0 1.1rem;
        text-wrap: balance;
        color: var(--text);
      }
      .band-copy p {
        color: var(--muted);
        font-size: 1.08rem;
        line-height: 1.65;
        max-width: 46ch;
        margin: 0 0 1.6rem;
      }
      .pills {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        margin: 0;
        padding: 0;
        list-style: none;
      }
      .pills li {
        padding: 0.5rem 0.95rem;
        border: 1px solid var(--border);
        border-radius: 999px;
        background: var(--surface);
        font-size: 0.9rem;
        color: var(--text);
        box-shadow: var(--shadow-sm);
      }

      /* ---------- safety ---------- */
      .safety {
        padding: clamp(4rem, 9vh, 7rem) 0;
        border-top: 1px solid var(--border);
        background:
          radial-gradient(60% 60% at 50% 0%, rgba(46, 77, 102, 0.05), transparent 70%),
          var(--bg-soft);
      }
      .safety-inner {
        text-align: center;
        max-width: 56rem;
        margin-inline: auto;
      }
      .safety-lede {
        color: var(--muted);
        font-size: 1.18rem;
        line-height: 1.6;
        max-width: 50ch;
        margin: 0 auto 2.8rem;
      }
      .safety-lede code {
        font-family: ui-monospace, 'SFMono-Regular', Menlo, monospace;
        color: var(--accent-ink);
        background: var(--accent-soft);
        padding: 0.1em 0.4em;
        border-radius: 5px;
        font-size: 0.92em;
      }
      .safety-points {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
        margin: 0;
        padding: 0;
        list-style: none;
        text-align: left;
      }
      .safety-points li {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        padding: 1.3rem 1.4rem;
        border: 1px solid var(--border);
        border-radius: 12px;
        background: var(--surface);
        box-shadow: var(--shadow-sm);
      }
      .safety-points strong {
        font-size: 1.05rem;
        color: var(--text);
      }
      .safety-points span {
        color: var(--muted);
        font-size: 0.95rem;
      }

      /* ---------- alpha ---------- */
      .alpha {
        padding: clamp(3.5rem, 8vh, 6rem) 0 clamp(4rem, 9vh, 7rem);
        border-top: 1px solid var(--border);
      }
      .alpha-inner {
        position: relative;
        text-align: center;
        max-width: 46rem;
        margin-inline: auto;
        padding: clamp(2.4rem, 5vw, 3.6rem);
        border: 1px solid var(--border);
        border-radius: 20px;
        background: var(--surface);
        box-shadow: var(--shadow-lg);
      }
      .alpha-inner::before {
        content: '';
        position: absolute;
        inset: 0 0 auto 0;
        height: 4px;
        border-radius: 20px 20px 0 0;
        background: linear-gradient(90deg, var(--accent), var(--blue));
      }
      .alpha-inner p {
        color: var(--muted);
        font-size: 1.1rem;
        line-height: 1.65;
        max-width: 48ch;
        margin: 0 auto 2rem;
      }
      .alpha-inner strong {
        color: var(--accent-ink);
      }

      /* ---------- footer ---------- */
      .site-footer {
        border-top: 1px solid var(--border);
        padding: 2.6rem 0;
        background: var(--bg-soft);
      }
      .footer-inner {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 1.2rem;
      }
      .footer-brand {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
      }
      .footer-brand img {
        border-radius: 7px;
      }
      .footer-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 1.4rem;
      }
      .footer-nav a {
        color: var(--muted);
        font-size: 0.95rem;
      }
      .footer-nav a:hover {
        color: var(--text);
      }
      .footer-note {
        width: 100%;
        margin: 0.5rem 0 0;
        color: var(--muted-2);
        font-size: 0.85rem;
      }

      /* ---------- responsive ---------- */
      @media (max-width: 900px) {
        .hero-grid {
          grid-template-columns: 1fr;
        }
        .hero-visual {
          order: -1;
        }
        .lede {
          max-width: none;
        }
        .band-grid,
        .band-plan .band-grid {
          grid-template-columns: 1fr;
        }
        .band-alt .band-copy {
          order: 0;
        }
        .trust-strip {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      @media (max-width: 680px) {
        .primary-nav ul {
          display: none;
        }
        .safety-points {
          grid-template-columns: 1fr;
        }
        /* Keep dense mockups legible on narrow screens. */
        .m-comp-prev {
          display: none;
        }
        .m-comp-body {
          grid-template-columns: 0.9fr 1.1fr;
        }
      }

      @media (max-width: 420px) {
        .trust-strip {
          grid-template-columns: 1fr;
        }
        .cta-row .btn {
          flex: 1 1 auto;
        }
        .m-sgrid {
          grid-template-columns: 1fr;
        }
      }
    </style>

    <script is:inline>
      // Theme toggle: flip data-theme, persist, keep the button label in sync.
      (function () {
        var btn = document.getElementById('theme-toggle');
        if (!btn) return;
        function sync() {
          var dark = document.documentElement.dataset.theme === 'dark';
          btn.setAttribute('aria-pressed', String(dark));
          btn.setAttribute(
            'aria-label',
            dark ? 'Switch to light theme' : 'Switch to dark theme'
          );
        }
        sync();
        btn.addEventListener('click', function () {
          var dark = document.documentElement.dataset.theme === 'dark';
          var next = dark ? 'light' : 'dark';
          document.documentElement.dataset.theme = next;
          try {
            localStorage.setItem('starlight-theme', next);
            localStorage.setItem('muse-theme', next);
          } catch (e) {}
          sync();
        });
      })();
    </script>
  </body>
</html>
