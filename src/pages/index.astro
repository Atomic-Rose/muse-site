---
// Bespoke MUSE landing page.
// Docs/manual routes remain on Starlight; only the homepage is custom.
import logo from '../assets/muse-logo.svg';

const base = import.meta.env.BASE_URL; // "/muse-site/"
const GITHUB = 'https://github.com/atomic-rose/muse-site';

const href = {
  download: `${base}alpha/install/`,
  manual: `${base}manual/getting-started/`,
  whatIsMuse: `${base}manual/what-is-muse/`,
  install: `${base}alpha/install/`,
  privacy: `${base}privacy/`,
  github: GITHUB,
};

const nav = [
  { label: 'Features', href: '#features' },
  { label: 'Safety', href: '#safety' },
  { label: 'Download', href: href.download },
  { label: 'Manual', href: href.manual },
  { label: 'GitHub', href: href.github },
];

const trust = [
  { label: 'Offline by default', note: 'Works with no internet connection.' },
  { label: 'One .muse file', note: 'Your whole book in a single document.' },
  { label: 'Automatic backups', note: 'Quiet, continuous protection.' },
  { label: 'No account or telemetry', note: 'Nothing is uploaded, ever.' },
];

// Consistent stroke line-icons used across feature/safety sections.
const sw = 'stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"';
const icons = {
  organize: `<svg viewBox="0 0 24 24" fill="none" ${sw} aria-hidden="true"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M9 4v16"/><path d="M5.4 8h1.6M5.4 11.5h1.6M12.5 8.5h5M12.5 12h5M12.5 15.5h3"/></svg>`,
  plan: `<svg viewBox="0 0 24 24" fill="none" ${sw} aria-hidden="true"><rect x="3" y="3" width="7.5" height="7.5" rx="1.4"/><rect x="13.5" y="3" width="7.5" height="7.5" rx="1.4"/><rect x="3" y="13.5" width="7.5" height="7.5" rx="1.4"/><rect x="13.5" y="13.5" width="7.5" height="7.5" rx="1.4"/></svg>`,
  revise: `<svg viewBox="0 0 24 24" fill="none" ${sw} aria-hidden="true"><path d="M12 20h9"/><path d="M16.4 3.6a2.1 2.1 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>`,
  exportFmt: `<svg viewBox="0 0 24 24" fill="none" ${sw} aria-hidden="true"><path d="M12 15V3"/><path d="m8 7 4-4 4 4"/><path d="M4 14v5a1 1 0 0 0 1 1h14a1 1 0 0 0 1-1v-5"/></svg>`,
  safety: `<svg viewBox="0 0 24 24" fill="none" ${sw} aria-hidden="true"><path d="M12 3 5 6v5c0 4.5 3 7.6 7 9 4-1.4 7-4.5 7-9V6Z"/><path d="m9.4 12 1.9 1.9L15 10"/></svg>`,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <title>MUSE — One calm studio for the whole book</title>
    <meta
      name="description"
      content="MUSE is an offline desktop writing app for novelists and long-form writers — plan, draft, revise, and export a manuscript without giving your work to the cloud."
    />
    <meta property="og:title" content="MUSE — One calm studio for the whole book" />
    <meta
      property="og:description"
      content="An offline desktop writing app for novelists and long-form writers. Plan, draft, revise, and export a whole book — your work stays on your computer."
    />
    <meta property="og:type" content="website" />
    <script is:inline>
      // Set the theme before paint to avoid a flash of the wrong theme.
      (function () {
        try {
          var stored = localStorage.getItem('muse-theme');
          var theme =
            stored ||
            (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.dataset.theme = theme;
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header">
      <div class="wrap header-inner">
        <a class="brand" href={base} aria-label="MUSE home">
          <img src={logo.src} alt="" width="32" height="32" />
          <span class="wordmark">MUSE</span>
        </a>
        <nav class="primary-nav" aria-label="Primary">
          <ul>
            {
              nav.map((item) => (
                <li>
                  <a
                    href={item.href}
                    {...(item.label === 'GitHub'
                      ? { rel: 'noopener', target: '_blank' }
                      : {})}
                  >
                    {item.label}
                  </a>
                </li>
              ))
            }
          </ul>
          <button
            type="button"
            class="theme-toggle"
            id="theme-toggle"
            aria-label="Switch to dark theme"
            aria-pressed="false"
          >
            <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.8A8.5 8.5 0 1 1 11.2 3a6.6 6.6 0 0 0 9.8 9.8Z"/></svg>
            <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
          </button>
          <a class="btn btn-primary btn-sm nav-cta" href={href.download}>Download</a>
        </nav>
      </div>
    </header>

    <main id="main">
      <!-- HERO -->
      <section class="hero" aria-labelledby="hero-heading">
        <div class="wrap hero-grid">
          <div class="hero-copy">
            <p class="eyebrow">
              <img src={logo.src} alt="" width="20" height="20" aria-hidden="true" />
              Manuscript Unified Studio Environment
            </p>
            <h1 id="hero-heading">One calm studio for the whole book.</h1>
            <p class="lede">
              MUSE is an offline desktop writing app for novelists and long-form
              writers — built to help you plan, draft, revise, and export a manuscript
              without giving your work to the cloud.
            </p>
            <div class="cta-row">
              <a class="btn btn-primary" href={href.download}>Download the alpha</a>
              <a class="btn btn-ghost" href={href.manual}>Read the manual</a>
            </div>
            <p class="platforms">Windows 11 · macOS · Linux · Private alpha</p>
          </div>

          <div class="hero-visual" aria-hidden="true">
            <div class="app-window">
              <div class="title-bar">
                <span class="dot"></span><span class="dot"></span><span class="dot"></span>
                <span class="title-bar-name">Northwind.muse</span>
              </div>
              <div class="app-body">
                <aside class="mk-binder">
                  <p class="mk-eyebrow">Binder</p>
                  <ul>
                    <li class="folder open">Manuscript</li>
                    <li class="doc">1 · The harbor</li>
                    <li class="doc"><span class="lab gold"></span>7 · The crossing</li>
                    <li class="doc active"><span class="lab blue"></span>8 · Low water</li>
                    <li class="doc">9 · Landfall</li>
                    <li class="folder">Characters</li>
                    <li class="doc">Mara Vance</li>
                    <li class="folder">Research</li>
                    <li class="doc">Tide tables</li>
                  </ul>
                </aside>
                <div class="mk-editor">
                  <p class="mk-synopsis">Mara reaches the far shore at slack tide.</p>
                  <p class="mk-chapter">Chapter Eight</p>
                  <p class="mk-line w-90"></p>
                  <p class="mk-line w-full"></p>
                  <p class="mk-line w-80"></p>
                  <p class="mk-line w-full"></p>
                  <p class="mk-line w-70 caret"></p>
                  <p class="mk-line w-95"></p>
                  <p class="mk-line w-60"></p>
                </div>
                <aside class="mk-inspector">
                  <p class="mk-eyebrow">Scene cards</p>
                  <div class="mk-card"><span class="mk-card-bar gold"></span>The crossing</div>
                  <div class="mk-card active"><span class="mk-card-bar blue"></span>Low water</div>
                  <div class="mk-card"><span class="mk-card-bar"></span>Landfall</div>
                  <p class="mk-eyebrow mt">Session</p>
                  <div class="mk-goal"><span style="width:68%"></span></div>
                  <p class="mk-goal-label">1,224 / 1,800 words</p>
                </aside>
              </div>
              <div class="status-bar">
                <span>Saved</span><span>80,412 words</span><span>Suggesting</span>
              </div>
            </div>
            <div class="hero-glow"></div>
          </div>
        </div>

        <!-- TRUST STRIP -->
        <div class="wrap">
          <ul class="trust-strip">
            {
              trust.map((t) => (
                <li>
                  <span class="trust-tick" aria-hidden="true" />
                  <span class="trust-text">
                    <span class="trust-label">{t.label}</span>
                    <span class="trust-note">{t.note}</span>
                  </span>
                </li>
              ))
            }
          </ul>
        </div>
      </section>

      <!-- FEATURES -->
      <div id="features"></div>

      <section class="band" aria-labelledby="f1">
        <div class="wrap band-grid">
          <div class="band-copy">
            <span class="sec-icon" set:html={icons.organize} />
            <p class="kicker">Organize</p>
            <h2 id="f1">Organize a whole manuscript.</h2>
            <p>
              Keep chapters, scenes, characters, places, and research in one
              drag-and-drop binder — your entire book in a single window.
            </p>
            <ul class="pills">
              <li>Drag-and-drop binder</li>
              <li>Labels, status &amp; metadata</li>
              <li>Smart collections</li>
            </ul>
          </div>
          <div class="band-visual" aria-hidden="true">
            <div class="mini mini-binder">
              <p class="mk-eyebrow">Binder</p>
              <ul>
                <li class="folder open">Part One</li>
                <li class="doc"><span class="lab gold"></span>Chapter 1 · The harbor</li>
                <li class="doc"><span class="lab blue"></span>Chapter 2 · Slack tide</li>
                <li class="doc dragging"><span class="lab gold"></span>Chapter 3 · The crossing</li>
                <li class="folder">Characters</li>
                <li class="doc">Mara Vance</li>
                <li class="doc">Captain Roe</li>
                <li class="folder">Research</li>
                <li class="doc">Tide tables</li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <section class="band band-alt band-plan" aria-labelledby="f2">
        <div class="wrap band-grid">
          <div class="band-copy">
            <span class="sec-icon" set:html={icons.plan} />
            <p class="kicker">Plan</p>
            <h2 id="f2">See the story before you rewrite it.</h2>
            <p>
              Step back from the page and view your manuscript as a whole — rearrange
              scenes, follow your timeline, and spot structural problems before they
              cost you a draft.
            </p>
            <ul class="pills">
              <li>Corkboard &amp; canvas</li>
              <li>Timeline</li>
              <li>Structure &amp; tension</li>
            </ul>
          </div>
          <div class="band-visual" aria-hidden="true">
            <div class="mini mini-board">
              <div class="board-tabs">
                <span class="tab active">Corkboard</span>
                <span class="tab">Timeline</span>
                <span class="tab">Structure</span>
              </div>
              <div class="board-grid">
                <div class="board-card"><span class="mk-card-bar gold"></span><b>The crossing</b><i></i><i class="s"></i></div>
                <div class="board-card"><span class="mk-card-bar blue"></span><b>Low water</b><i></i><i class="s"></i></div>
                <div class="board-card"><span class="mk-card-bar"></span><b>Landfall</b><i></i><i class="s"></i></div>
                <div class="board-card"><span class="mk-card-bar blue"></span><b>The wreck</b><i></i><i class="s"></i></div>
              </div>
              <div class="tension">
                <span class="tension-label">Tension</span>
                <svg viewBox="0 0 220 44" preserveAspectRatio="none"
                  ><path d="M0 34 C 40 34, 50 12, 78 16 S 128 4, 158 22 S 205 8, 220 11"
                    fill="none" stroke="currentColor" stroke-width="2" /></svg>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="band" aria-labelledby="f3">
        <div class="wrap band-grid">
          <div class="band-copy">
            <span class="sec-icon" set:html={icons.revise} />
            <p class="kicker">Write &amp; revise</p>
            <h2 id="f3">Write and revise without friction.</h2>
            <p>
              A fast editor that stays smooth at 80,000 words, with the revision tools a
              serious draft needs — tracked changes, comments, and snapshots you can roll
              back to.
            </p>
            <ul class="pills">
              <li>Focus mode &amp; typewriter</li>
              <li>Wikilinks &amp; backlinks</li>
              <li>Tracked changes &amp; snapshots</li>
            </ul>
          </div>
          <div class="band-visual" aria-hidden="true">
            <div class="mini mini-revise">
              <div class="revise-tag"><span class="dot-sm"></span>Revision pass · Line edit</div>
              <p class="mk-line w-90"></p>
              <p class="mk-line w-full"></p>
              <p class="revise-change w-80">
                A <span class="ins">new dawn</span> <span class="del">grey morning</span> over the bay.
              </p>
              <p class="mk-line w-95"></p>
              <p class="mk-line w-70"></p>
              <div class="comment">
                <span class="comment-who">Editor</span>
                “Tighten this beat — land on the image.”
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="band band-alt" aria-labelledby="f4">
        <div class="wrap band-grid">
          <div class="band-copy">
            <span class="sec-icon" set:html={icons.exportFmt} />
            <p class="kicker">Export</p>
            <h2 id="f4">Export to real manuscript formats.</h2>
            <p>
              Compile the documents you choose into a finished manuscript and export to
              the formats editors and agents actually use.
            </p>
            <ul class="pills">
              <li>DOCX with tracked changes</li>
              <li>PDF</li>
              <li>Markdown</li>
            </ul>
          </div>
          <div class="band-visual" aria-hidden="true">
            <div class="mini mini-export">
              <p class="mk-eyebrow">Compile</p>
              <div class="export-body">
                <div class="page">
                  <p class="page-title">Northwind</p>
                  <p class="mk-line w-60"></p>
                  <p class="mk-line w-full"></p>
                  <p class="mk-line w-90"></p>
                  <p class="mk-line w-full"></p>
                  <p class="mk-line w-80"></p>
                </div>
                <div class="export-formats">
                  <div class="fmt active"><span class="fmt-name">DOCX</span><span class="fmt-check">✓</span></div>
                  <div class="fmt"><span class="fmt-name">PDF</span></div>
                  <div class="fmt"><span class="fmt-name">Markdown</span></div>
                  <div class="export-cta">Compile manuscript</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- SAFETY -->
      <section id="safety" class="safety" aria-labelledby="safety-heading">
        <div class="wrap safety-inner">
          <span class="sec-icon center" set:html={icons.safety} />
          <p class="kicker center">Ownership</p>
          <h2 id="safety-heading">Your manuscript stays yours.</h2>
          <p class="safety-lede">
            MUSE stores your project locally in a single <code>.muse</code> file on your
            own disk. No cloud account, no sync service, no telemetry.
          </p>
          <ul class="safety-points">
            <li><strong>Automatic backups</strong><span>Quiet, continuous copies as you work.</span></li>
            <li><strong>Version snapshots</strong><span>Roll a document back to an earlier draft.</span></li>
            <li><strong>Crash-recovery drafts</strong><span>Unsaved work is restored on reopen.</span></li>
            <li><strong>Yours to move</strong><span>Copy the file to a USB stick or any folder.</span></li>
          </ul>
        </div>
      </section>

      <!-- ALPHA -->
      <section class="alpha" aria-labelledby="alpha-heading">
        <div class="wrap">
          <div class="alpha-inner">
            <p class="kicker center">Early access</p>
            <h2 id="alpha-heading">Now in private alpha.</h2>
            <p>
              MUSE is in early testing. Expect rough edges, keep backups of work you cannot
              afford to lose, and help shape the 1.0 release. Alpha and beta testers receive
              a permanent <strong>50% discount code</strong> at launch.
            </p>
            <div class="cta-row center">
              <a class="btn btn-primary" href={href.download}>Download the alpha</a>
              <a class="btn btn-ghost" href={href.install}>Read install instructions</a>
            </div>
          </div>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div class="wrap footer-inner">
        <div class="footer-brand">
          <img src={logo.src} alt="" width="28" height="28" />
          <span class="wordmark">MUSE</span>
        </div>
        <nav class="footer-nav" aria-label="Footer">
          <a href={href.whatIsMuse}>What is MUSE?</a>
          <a href={href.manual}>Manual</a>
          <a href={href.privacy}>Privacy</a>
          <a href={href.github} rel="noopener" target="_blank">GitHub</a>
        </nav>
        <p class="footer-note">
          Private alpha · keep backups of anything you can’t afford to lose.
        </p>
      </div>
    </footer>

    <style is:global>
      :root {
        /* Clean, elegant light theme — warm paper, deep-blue ink accent. */
        --bg: #fbfaf7;
        --bg-soft: #f3f1ea;
        --surface: #ffffff;
        --text: #1c2a33;
        --muted: #586771;
        --muted-2: #8b949b;
        --border: #e7e2d7;
        --border-soft: #eee9df;

        --accent: #2e4d66; /* logo deep blue */
        --accent-hover: #243f56;
        --accent-soft: #e9eff4; /* light blue highlight */
        --accent-ink: #20384b;
        --gold: #b08a36; /* used sparingly */
        --blue: #6a9dbe;

        /* Component tokens that the dark theme remaps. */
        --btn-bg: #284763;
        --btn-bg-hover: #1f3a52;
        --btn-text: #ffffff;
        --skeleton: rgba(28, 42, 51, 0.09);
        --window-dot: #cfc9bb;

        --shadow-sm: 0 1px 2px rgba(28, 42, 51, 0.06);
        --shadow-md: 0 10px 30px -14px rgba(28, 42, 51, 0.22);
        --shadow-lg: 0 30px 60px -28px rgba(28, 42, 51, 0.28);

        --maxw: 74rem;
        --radius: 14px;
        --font-sans: ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto,
          'Helvetica Neue', Arial, sans-serif;
        --font-serif: 'Iowan Old Style', 'Palatino Linotype', Palatino, Georgia,
          'Times New Roman', serif;
      }

      /* Clean, elegant dark theme — deep slate, soft light ink, brighter blue. */
      :root[data-theme='dark'] {
        --bg: #0f161b;
        --bg-soft: #141d24;
        --surface: #18222a;
        --text: #eef2f4;
        --muted: #a6b2ba;
        --muted-2: #74828b;
        --border: #2a3640;
        --border-soft: #232e37;

        --accent: #84b3da;
        --accent-hover: #9cc4e6;
        --accent-soft: rgba(132, 179, 218, 0.16);
        --accent-ink: #d3e4f1;
        --gold: #cda85a;
        --blue: #8fb7d9;

        --btn-bg: #84b3da;
        --btn-bg-hover: #9cc4e6;
        --btn-text: #0e151a;
        --skeleton: rgba(245, 248, 250, 0.11);
        --window-dot: #3a4750;

        --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.4);
        --shadow-md: 0 12px 30px -14px rgba(0, 0, 0, 0.6);
        --shadow-lg: 0 34px 64px -30px rgba(0, 0, 0, 0.7);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      html,
      body {
        margin: 0;
        max-width: 100%;
        overflow-x: hidden;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--font-sans);
        font-size: 1.06rem;
        line-height: 1.7;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      img {
        max-width: 100%;
        height: auto;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      :focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
        border-radius: 4px;
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
        * {
          transition-duration: 0.01ms !important;
          animation-duration: 0.01ms !important;
          animation-iteration-count: 1 !important;
        }
      }
    </style>

    <style>
      .wrap {
        width: 100%;
        max-width: var(--maxw);
        margin-inline: auto;
        padding-inline: clamp(1.1rem, 4vw, 2.5rem);
      }

      .skip-link {
        position: absolute;
        left: -9999px;
        top: 0;
        background: var(--btn-bg);
        color: var(--btn-text);
        padding: 0.6rem 1rem;
        font-weight: 600;
        z-index: 100;
      }
      .skip-link:focus {
        left: 1rem;
        top: 1rem;
      }

      /* ---------- buttons ---------- */
      .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        font-family: var(--font-sans);
        font-weight: 600;
        font-size: 1rem;
        line-height: 1;
        padding: 0.88rem 1.55rem;
        border-radius: 10px;
        border: 1px solid transparent;
        cursor: pointer;
        transition:
          transform 0.16s ease,
          background-color 0.16s ease,
          border-color 0.16s ease,
          box-shadow 0.16s ease;
      }
      .btn-sm {
        padding: 0.5rem 1.05rem;
        font-size: 0.92rem;
        border-radius: 8px;
      }
      .btn-primary {
        background: var(--btn-bg);
        color: var(--btn-text);
        box-shadow: var(--shadow-sm);
      }
      .btn-primary:hover {
        background: var(--btn-bg-hover);
        transform: translateY(-1px);
        box-shadow: var(--shadow-md);
      }
      .btn-ghost {
        background: var(--surface);
        color: var(--text);
        border-color: var(--border);
        box-shadow: var(--shadow-sm);
      }
      .btn-ghost:hover {
        border-color: var(--muted-2);
        transform: translateY(-1px);
        box-shadow: var(--shadow-md);
      }

      /* ---------- header ---------- */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: color-mix(in srgb, var(--bg) 82%, transparent);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid var(--border);
      }
      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 64px;
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
      }
      .brand img {
        border-radius: 8px;
      }
      .wordmark {
        font-family: var(--font-sans);
        font-weight: 700;
        letter-spacing: 0.2em;
        font-size: 1rem;
        color: var(--text);
      }
      .primary-nav {
        display: flex;
        align-items: center;
        gap: 1.5rem;
      }
      .primary-nav ul {
        display: flex;
        align-items: center;
        gap: 1.7rem;
        margin: 0;
        padding: 0;
        list-style: none;
      }
      .primary-nav ul a {
        color: var(--muted);
        font-size: 0.95rem;
        font-weight: 500;
        transition: color 0.15s ease;
      }
      .primary-nav ul a:hover {
        color: var(--text);
      }
      .nav-cta {
        white-space: nowrap;
        font-weight: 700;
        letter-spacing: 0.01em;
      }

      /* ---------- theme toggle ---------- */
      .theme-toggle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 38px;
        height: 38px;
        padding: 0;
        border: 1px solid var(--border);
        border-radius: 9px;
        background: var(--surface);
        color: var(--muted);
        cursor: pointer;
        transition:
          color 0.15s ease,
          border-color 0.15s ease,
          background-color 0.15s ease;
      }
      .theme-toggle:hover {
        color: var(--text);
        border-color: var(--muted-2);
      }
      .theme-toggle svg {
        width: 18px;
        height: 18px;
      }
      .theme-toggle .icon-sun {
        display: none;
      }
      :root[data-theme='dark'] .theme-toggle .icon-sun {
        display: block;
      }
      :root[data-theme='dark'] .theme-toggle .icon-moon {
        display: none;
      }

      /* ---------- hero ---------- */
      .hero {
        position: relative;
        padding-top: clamp(3rem, 7vh, 5.5rem);
        padding-bottom: clamp(2.5rem, 6vh, 4.5rem);
        background:
          radial-gradient(46% 40% at 82% 6%, rgba(106, 157, 190, 0.12), transparent 70%);
      }
      .hero-grid {
        display: grid;
        grid-template-columns: 1fr 1.1fr;
        gap: clamp(2rem, 5vw, 4.5rem);
        align-items: center;
      }
      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
        margin: 0 0 1.2rem;
        color: var(--accent);
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.15em;
        text-transform: uppercase;
      }
      .eyebrow img {
        border-radius: 6px;
      }
      h1 {
        font-family: var(--font-serif);
        font-weight: 600;
        font-size: clamp(2.3rem, 4.4vw, 3.5rem);
        line-height: 1.08;
        letter-spacing: -0.02em;
        margin: 0 0 1.3rem;
        text-wrap: balance;
      }
      .lede {
        color: var(--muted);
        font-size: clamp(1.08rem, 1.4vw, 1.22rem);
        line-height: 1.62;
        max-width: 42ch;
        margin: 0 0 2rem;
      }
      .cta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.9rem;
      }
      .cta-row.center {
        justify-content: center;
      }
      .platforms {
        margin: 1.6rem 0 0;
        color: var(--muted-2);
        font-size: 0.92rem;
        letter-spacing: 0.02em;
      }

      /* ---------- hero app mockup ---------- */
      .hero-visual {
        position: relative;
      }
      .hero-glow {
        position: absolute;
        inset: 10% 4% 4% 10%;
        z-index: -1;
        background: radial-gradient(closest-side, rgba(46, 77, 102, 0.16), transparent);
        filter: blur(50px);
      }
      .app-window {
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: var(--surface);
        box-shadow: var(--shadow-lg);
        overflow: hidden;
      }
      .title-bar {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.7rem 0.9rem;
        border-bottom: 1px solid var(--border);
        background: var(--bg-soft);
      }
      .title-bar .dot {
        width: 11px;
        height: 11px;
        border-radius: 50%;
        background: var(--window-dot);
      }
      .title-bar-name {
        margin-left: 0.7rem;
        color: var(--muted-2);
        font-size: 0.78rem;
        letter-spacing: 0.01em;
      }
      .app-body {
        display: grid;
        grid-template-columns: 0.82fr 1.55fr 0.92fr;
        min-height: 360px;
      }
      .mk-binder,
      .mk-inspector {
        padding: 0.95rem 0.85rem;
        font-size: 0.74rem;
      }
      .mk-binder {
        border-right: 1px solid var(--border);
        background: #faf8f3;
      }
      .mk-inspector {
        border-left: 1px solid var(--border);
        background: #fbfaf6;
      }
      .mk-eyebrow {
        margin: 0 0 0.7rem;
        color: var(--muted-2);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 0.62rem;
      }
      .mk-eyebrow.mt {
        margin-top: 1.2rem;
      }
      .mk-binder ul {
        margin: 0;
        padding: 0;
        list-style: none;
        display: grid;
        gap: 0.26rem;
      }
      .mk-binder li {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.22rem 0.5rem;
        border-radius: 6px;
        color: var(--muted);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .mk-binder li.folder {
        color: var(--text);
        font-weight: 600;
      }
      .mk-binder li.folder::before {
        content: '▸';
        color: var(--muted-2);
        font-size: 0.7em;
      }
      .mk-binder li.folder.open::before {
        content: '▾';
      }
      .mk-binder li.doc {
        padding-left: 1.2rem;
      }
      .mk-binder li.active {
        background: var(--accent-soft);
        color: var(--accent-ink);
        font-weight: 600;
      }
      .lab {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: var(--muted-2);
        flex: none;
      }
      .lab.gold {
        background: var(--gold);
      }
      .lab.blue {
        background: var(--blue);
      }
      .mk-editor {
        padding: 1.6rem 1.7rem;
        background: var(--surface);
      }
      .mk-synopsis {
        margin: 0 0 1.2rem;
        padding: 0.5rem 0.7rem;
        border-left: 2px solid var(--accent);
        background: var(--accent-soft);
        border-radius: 0 6px 6px 0;
        color: var(--accent-ink);
        font-size: 0.78rem;
        font-style: italic;
      }
      .mk-chapter {
        font-family: var(--font-serif);
        font-size: 1.2rem;
        margin: 0 0 1.1rem;
        color: var(--text);
      }
      .mk-line {
        height: 0.58rem;
        border-radius: 4px;
        background: var(--skeleton);
        margin: 0 0 0.72rem;
      }
      .mk-line.w-full { width: 100%; }
      .mk-line.w-95 { width: 95%; }
      .mk-line.w-90 { width: 90%; }
      .mk-line.w-80 { width: 80%; }
      .mk-line.w-70 { width: 70%; }
      .mk-line.w-60 { width: 60%; }
      .mk-line.caret {
        position: relative;
      }
      .mk-line.caret::after {
        content: '';
        position: absolute;
        right: -4px;
        top: -2px;
        width: 2px;
        height: 1rem;
        background: var(--accent);
        animation: blink 1.1s steps(2, start) infinite;
      }
      @keyframes blink {
        50% { opacity: 0; }
      }
      .mk-card {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 0.55rem;
        margin-bottom: 0.5rem;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--surface);
        color: var(--muted);
        font-size: 0.72rem;
        box-shadow: var(--shadow-sm);
      }
      .mk-card.active {
        border-color: var(--accent);
        color: var(--text);
      }
      .mk-card-bar {
        width: 4px;
        align-self: stretch;
        border-radius: 2px;
        background: #c8d0d6;
      }
      .mk-card-bar.gold { background: var(--gold); }
      .mk-card-bar.blue { background: var(--blue); }
      .mk-goal {
        height: 6px;
        border-radius: 999px;
        background: var(--skeleton);
        overflow: hidden;
      }
      .mk-goal span {
        display: block;
        height: 100%;
        background: var(--accent);
      }
      .mk-goal-label {
        margin: 0.45rem 0 0;
        color: var(--muted-2);
        font-size: 0.66rem;
      }
      .status-bar {
        display: flex;
        gap: 1.4rem;
        padding: 0.5rem 1rem;
        border-top: 1px solid var(--border);
        background: var(--bg-soft);
        color: var(--muted-2);
        font-size: 0.68rem;
        letter-spacing: 0.03em;
      }
      .status-bar span:last-child {
        margin-left: auto;
        color: var(--accent);
        font-weight: 600;
      }

      /* ---------- trust strip ---------- */
      .trust-strip {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 1px;
        margin: clamp(2.5rem, 6vh, 4rem) 0 0;
        padding: 0;
        list-style: none;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
        background: var(--border);
        box-shadow: var(--shadow-sm);
      }
      .trust-strip li {
        display: flex;
        align-items: flex-start;
        gap: 0.7rem;
        padding: 1.2rem 1.3rem;
        background: var(--surface);
      }
      .trust-tick {
        margin-top: 0.45rem;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        flex: none;
        background: var(--accent);
        box-shadow: 0 0 0 3px var(--accent-soft);
      }
      .trust-text {
        display: flex;
        flex-direction: column;
        gap: 0.2rem;
      }
      .trust-label {
        font-weight: 600;
        font-size: 0.98rem;
      }
      .trust-note {
        color: var(--muted);
        font-size: 0.84rem;
        line-height: 1.45;
      }

      /* ---------- section icon badge ---------- */
      .sec-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 42px;
        height: 42px;
        margin-bottom: 1.1rem;
        border: 1px solid var(--border);
        border-radius: 11px;
        background: var(--surface);
        color: var(--accent);
        box-shadow: var(--shadow-sm);
      }
      .sec-icon.center {
        margin-inline: auto;
      }
      .sec-icon svg {
        width: 21px;
        height: 21px;
      }

      /* ---------- feature bands ---------- */
      .band {
        padding: clamp(3.5rem, 8vh, 6rem) 0;
        border-top: 1px solid var(--border-soft);
      }
      .band-alt {
        background: var(--bg-soft);
      }
      .band-grid {
        display: grid;
        grid-template-columns: 1fr 1.05fr;
        gap: clamp(2rem, 5vw, 5rem);
        align-items: center;
      }
      .band-alt .band-copy {
        order: 2;
      }
      .band-plan .band-grid {
        grid-template-columns: 1fr 1.2fr;
      }
      .kicker {
        margin: 0 0 0.7rem;
        color: var(--accent);
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }
      .kicker.center {
        text-align: center;
      }
      h2 {
        font-family: var(--font-serif);
        font-weight: 600;
        font-size: clamp(1.8rem, 3vw, 2.5rem);
        line-height: 1.12;
        letter-spacing: -0.015em;
        margin: 0 0 1.1rem;
        text-wrap: balance;
        color: var(--text);
      }
      .band-copy p {
        color: var(--muted);
        font-size: 1.08rem;
        line-height: 1.65;
        max-width: 46ch;
        margin: 0 0 1.6rem;
      }
      .pills {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem;
        margin: 0;
        padding: 0;
        list-style: none;
      }
      .pills li {
        padding: 0.5rem 0.95rem;
        border: 1px solid var(--border);
        border-radius: 999px;
        background: var(--surface);
        font-size: 0.9rem;
        color: var(--text);
        box-shadow: var(--shadow-sm);
      }

      /* ---------- band visuals ---------- */
      .mini {
        position: relative;
        border: 1px solid var(--border);
        border-radius: var(--radius);
        background: var(--surface);
        box-shadow: var(--shadow-lg);
        padding: 1.5rem;
        min-height: 280px;
      }
      .mini-binder ul {
        margin: 0.4rem 0 0;
        padding: 0;
        list-style: none;
        display: grid;
        gap: 0.4rem;
      }
      .mini-binder li {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.45rem 0.7rem;
        border-radius: 8px;
        color: var(--muted);
        font-size: 0.92rem;
        border: 1px solid transparent;
      }
      .mini-binder li.folder {
        color: var(--text);
        font-weight: 600;
      }
      .mini-binder li.folder::before {
        content: '▾';
        color: var(--muted-2);
        font-size: 0.75em;
      }
      .mini-binder li.doc {
        padding-left: 1.5rem;
      }
      .mini-binder li.dragging {
        background: var(--accent-soft);
        border-color: var(--accent);
        color: var(--accent-ink);
        transform: translateX(6px);
        box-shadow: var(--shadow-md);
      }

      .mini-board {
        display: flex;
        flex-direction: column;
        gap: 0.9rem;
      }
      .board-tabs {
        display: flex;
        gap: 0.4rem;
      }
      .board-tabs .tab {
        padding: 0.35rem 0.8rem;
        border-radius: 999px;
        font-size: 0.78rem;
        color: var(--muted);
        border: 1px solid transparent;
      }
      .board-tabs .tab.active {
        color: var(--accent-ink);
        border-color: var(--border);
        background: var(--accent-soft);
        font-weight: 600;
      }
      .board-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.8rem;
      }
      .board-card {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.5rem 0.6rem;
        padding: 0.8rem;
        border: 1px solid var(--border);
        border-radius: 10px;
        background: var(--bg);
      }
      .board-card b {
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--text);
      }
      .board-card .mk-card-bar {
        flex: 0 0 4px;
        align-self: stretch;
      }
      .board-card i {
        display: block;
        height: 0.45rem;
        background: var(--skeleton);
        border-radius: 3px;
        flex: 1 1 100%;
      }
      .board-card i.s {
        flex-basis: 50%;
      }
      .tension {
        display: flex;
        align-items: center;
        gap: 0.7rem;
        color: var(--accent);
        border: 1px solid var(--border);
        border-radius: 10px;
        background: var(--bg);
        padding: 0.55rem 0.8rem;
      }
      .tension-label {
        color: var(--muted-2);
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        flex: none;
      }
      .tension svg {
        display: block;
        width: 100%;
        height: 38px;
      }

      .mini-revise .mk-line {
        height: 0.62rem;
      }
      .revise-tag {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        margin-bottom: 1.1rem;
        padding: 0.35rem 0.7rem;
        border: 1px solid var(--border);
        border-radius: 999px;
        background: var(--accent-soft);
        color: var(--accent-ink);
        font-size: 0.74rem;
        font-weight: 600;
      }
      .dot-sm {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--accent);
      }
      .revise-change {
        font-size: 0.98rem;
        line-height: 1.7;
        color: var(--text);
        margin: 0 0 0.72rem;
      }
      .ins {
        color: #1f7a44;
        border-bottom: 2px solid rgba(31, 122, 68, 0.5);
      }
      .del {
        color: #b23b3b;
        text-decoration: line-through;
      }
      .comment {
        margin-top: 1.2rem;
        margin-left: auto;
        max-width: 78%;
        padding: 0.75rem 0.9rem;
        border: 1px solid var(--border);
        border-left: 3px solid var(--gold);
        border-radius: 8px;
        background: var(--bg);
        color: var(--muted);
        font-size: 0.88rem;
        font-style: italic;
      }
      .comment-who {
        display: block;
        margin-bottom: 0.2rem;
        color: var(--gold);
        font-style: normal;
        font-weight: 700;
        font-size: 0.72rem;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .mini-export .export-body {
        display: grid;
        grid-template-columns: 1.15fr 1fr;
        gap: 1rem;
        margin-top: 0.5rem;
      }
      .mini-export .page {
        padding: 1.1rem;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--bg);
      }
      .page-title {
        font-family: var(--font-serif);
        text-align: center;
        font-size: 1rem;
        margin: 0 0 1rem;
        color: var(--text);
      }
      .export-formats {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
      }
      .fmt {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.6rem 0.8rem;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--surface);
        color: var(--muted);
        font-size: 0.86rem;
        font-weight: 600;
      }
      .fmt.active {
        border-color: var(--accent);
        background: var(--accent-soft);
        color: var(--accent-ink);
      }
      .fmt-check {
        color: var(--accent);
      }
      .export-cta {
        margin-top: auto;
        text-align: center;
        padding: 0.6rem;
        border-radius: 8px;
        background: var(--btn-bg);
        color: var(--btn-text);
        font-size: 0.86rem;
        font-weight: 600;
      }

      /* ---------- safety ---------- */
      .safety {
        padding: clamp(4rem, 9vh, 7rem) 0;
        border-top: 1px solid var(--border);
        background:
          radial-gradient(60% 60% at 50% 0%, rgba(46, 77, 102, 0.05), transparent 70%),
          var(--bg-soft);
      }
      .safety-inner {
        text-align: center;
        max-width: 56rem;
        margin-inline: auto;
      }
      .safety-lede {
        color: var(--muted);
        font-size: 1.18rem;
        line-height: 1.6;
        max-width: 50ch;
        margin: 0 auto 2.8rem;
      }
      .safety-lede code {
        font-family: ui-monospace, 'SFMono-Regular', Menlo, monospace;
        color: var(--accent-ink);
        background: var(--accent-soft);
        padding: 0.1em 0.4em;
        border-radius: 5px;
        font-size: 0.92em;
      }
      .safety-points {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
        margin: 0;
        padding: 0;
        list-style: none;
        text-align: left;
      }
      .safety-points li {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        padding: 1.3rem 1.4rem;
        border: 1px solid var(--border);
        border-radius: 12px;
        background: var(--surface);
        box-shadow: var(--shadow-sm);
      }
      .safety-points strong {
        font-size: 1.05rem;
        color: var(--text);
      }
      .safety-points span {
        color: var(--muted);
        font-size: 0.95rem;
      }

      /* ---------- alpha ---------- */
      .alpha {
        padding: clamp(3.5rem, 8vh, 6rem) 0 clamp(4rem, 9vh, 7rem);
        border-top: 1px solid var(--border);
      }
      .alpha-inner {
        position: relative;
        text-align: center;
        max-width: 46rem;
        margin-inline: auto;
        padding: clamp(2.4rem, 5vw, 3.6rem);
        border: 1px solid var(--border);
        border-radius: 20px;
        background: var(--surface);
        box-shadow: var(--shadow-lg);
      }
      .alpha-inner::before {
        content: '';
        position: absolute;
        inset: 0 0 auto 0;
        height: 4px;
        border-radius: 20px 20px 0 0;
        background: linear-gradient(90deg, var(--accent), var(--blue));
      }
      .alpha-inner p {
        color: var(--muted);
        font-size: 1.1rem;
        line-height: 1.65;
        max-width: 48ch;
        margin: 0 auto 2rem;
      }
      .alpha-inner strong {
        color: var(--accent-ink);
      }

      /* ---------- footer ---------- */
      .site-footer {
        border-top: 1px solid var(--border);
        padding: 2.6rem 0;
        background: var(--bg-soft);
      }
      .footer-inner {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 1.2rem;
      }
      .footer-brand {
        display: inline-flex;
        align-items: center;
        gap: 0.55rem;
      }
      .footer-brand img {
        border-radius: 7px;
      }
      .footer-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 1.4rem;
      }
      .footer-nav a {
        color: var(--muted);
        font-size: 0.95rem;
      }
      .footer-nav a:hover {
        color: var(--text);
      }
      .footer-note {
        width: 100%;
        margin: 0.5rem 0 0;
        color: var(--muted-2);
        font-size: 0.85rem;
      }

      /* ---------- responsive ---------- */
      @media (max-width: 900px) {
        .hero-grid {
          grid-template-columns: 1fr;
        }
        .hero-visual {
          order: -1;
        }
        .lede {
          max-width: none;
        }
        .band-grid,
        .band-plan .band-grid {
          grid-template-columns: 1fr;
        }
        .band-alt .band-copy {
          order: 0;
        }
        .trust-strip {
          grid-template-columns: repeat(2, 1fr);
        }
      }

      @media (max-width: 680px) {
        .primary-nav ul {
          display: none;
        }
        .safety-points {
          grid-template-columns: 1fr;
        }
        .app-body {
          grid-template-columns: 0.9fr 1.5fr;
        }
        .mk-inspector {
          display: none;
        }
        .mini-export .export-body {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 420px) {
        .trust-strip {
          grid-template-columns: 1fr;
        }
        .cta-row .btn {
          flex: 1 1 auto;
        }
        .board-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>

    <script is:inline>
      // Theme toggle: flip data-theme, persist, keep the button label in sync.
      (function () {
        var btn = document.getElementById('theme-toggle');
        if (!btn) return;
        function sync() {
          var dark = document.documentElement.dataset.theme === 'dark';
          btn.setAttribute('aria-pressed', String(dark));
          btn.setAttribute(
            'aria-label',
            dark ? 'Switch to light theme' : 'Switch to dark theme'
          );
        }
        sync();
        btn.addEventListener('click', function () {
          var dark = document.documentElement.dataset.theme === 'dark';
          var next = dark ? 'light' : 'dark';
          document.documentElement.dataset.theme = next;
          try {
            localStorage.setItem('muse-theme', next);
          } catch (e) {}
          sync();
        });
      })();
    </script>
  </body>
</html>
